        "Oh-my-Codex工作流",
        "$team模式并行审查",
        "$ri模式持久优化",
        "架构师级生产验证"
      ],
      "输出语言": "中文",
      "代码注释语言": "中文"
    },
    
    "4SAPI辩证": {
      "启用": true,
      "中文AI模型": [
        {
          "名称": "架构师AI",
          "角色": "系统架构设计",
          "描述": "负责系统架构规划和设计",
          "语言": "中文"
        },
        {
          "名称": "安全AI", 
          "角色": "安全风险评估",
          "描述": "负责安全漏洞分析和风险评估",
          "语言": "中文"
        },
        {
          "名称": "性能AI",
          "角色": "性能优化分析",
          "描述": "负责性能测试和优化方案",
          "语言": "中文"
        },
        {
          "名称": "质量AI",
          "角色": "代码质量审查",
          "描述": "负责代码规范和质量评估",
          "语言": "中文"
        },
        {
          "名称": "产品AI",
          "角色": "业务需求分析",
          "描述": "负责需求分析和用户体验",
          "语言": "中文"
        }
      ],
      "辩证轮次": 3,
      "共识机制": "中文辩证逻辑"
    },
    
    "集成服务": {
      "启用": true,
      "HTTP服务": {
        "端口": 3000,
        "语言": "中文",
        "接口": {
          "健康检查": "/health",
          "系统指标": "/metrics",
          "代码生成API": "/api/codegen",
          "控制面板": "/ui",
          "集成状态": "/api/integration/status"
        }
      },
      "监控": {
        "启用": true,
        "语言": "中文",
        "指标": ["CPU使用率", "内存使用", "响应时间", "错误率"]
      }
    }
  },
  
  "界面设置": {
    "主题": "中文深色",
    "字体": "微软雅黑",
