{
  "version": "1.0.0",
  "description": "4AI Workflow - Multi-Agent Orchestration with BIFROST",
  "routing": {
    "primary": "bifrost",
    "fallback": "foursapi"
  },
  "roles": {
    "scout": {
      "model": "foursapi/gemini-3.1-pro-preview",
      "description": "信息收集与关联分析",
      "timeout": 60000,
      "maxTokens": 16000,
      "temperature": 0.3,
      "tools": ["memory_search", "web_fetch", "exec", "query_database"]
    },
    "clarifier": {
      "model": "foursapi/gemini-3.1-pro-preview",
      "description": "需求分析与边界定义",
      "timeout": 120000,
      "maxTokens": 32000,
      "temperature": 0.2,
      "backup": "foursapi/claude-opus-4-7"
    },
    "builder": {
      "model": "foursapi/gemini-3.1-pro-preview",
      "description": "架构设计与代码生成",
      "timeout": 180000,
      "maxTokens": 64000,
      "temperature": 0.1,
      "backup": "foursapi/claude-opus-4-7"
    },
    "reviewer": {
      "model": "foursapi/claude-opus-4-7",
      "description": "安全审查与极限测试",
      "timeout": 180000,
      "maxTokens": 32000,
      "temperature": 0.1,
      "backup": "foursapi/gemini-3.1-pro-preview"
    },
    "arbiter": {
      "model": "foursapi/gemini-3.1-pro-preview",
      "description": "综合裁决与冲突解决",
      "timeout": 120000,
      "maxTokens": 32000,
      "temperature": 0.2,
      "backup": "foursapi/claude-opus-4-7"
    }
  },
  "resilience": {
    "circuitBreaker": {
      "enabled": true,
      "failureThreshold": 3,
      "resetTimeout": 30000,
      "halfOpenMaxCalls": 2
    },
    "retry": {
      "maxRetries": 3,
      "baseDelay": 1000,
      "maxDelay": 30000,
      "backoffMultiplier": 2
    },
    "timeout": {
      "global": 600000,
      "perRole": 300000
    }
  },
  "output": {
    "format": "structured",
    "includeConfidence": true,
    "includeToolCalls": true,
    "includeTiming": true
  }
}
